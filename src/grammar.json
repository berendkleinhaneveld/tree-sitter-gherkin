        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_triple_backtick"
            },
            {
              "type": "SYMBOL",
              "name": "_nl"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "SYMBOL",
                "name": "_docstring_line"
              }
            },
            {
              "type": "SYMBOL",
              "name": "_triple_backtick"
            },
            {
              "type": "SYMBOL",
              "name": "_nl"
            }
          ]
        }
      ]
    },
    "_triple_dquote": {
      "type": "STRING",
      "value": "\"\"\""
    },
    "_triple_backtick": {
      "type": "STRING",
      "value": "```"
    },
    "_docstring_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "docstring_content"
