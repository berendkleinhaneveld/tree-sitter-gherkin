        {
          "type": "STRING",
          "value": "And"
        },
        {
          "type": "STRING",
          "value": "But"
        },
        {
          "type": "STRING",
          "value": "*"
        }
      ]
    },
    "step_text": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "parameter"
          },
          {
            "type": "SYMBOL",
            "name": "string"
          },
          {
            "type": "SYMBOL",
            "name": "number"
