    "parameter": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "<[^>\\n\\r]*>"
        }
      }
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "\"[^\"\\n\\r]*\""
            },
            {
              "type": "PATTERN",
              "value": "'[^'\\n\\r]*'"
            }
          ]
        }
      }
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "-?\\d+(\\.\\d+)?"
        }
      }
    },
    "table_row": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "|"
